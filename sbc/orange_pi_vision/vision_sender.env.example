# OrbbecSDK v1 SDK directory on the Orange Pi AI Pro 8T.
ORBBEC_SDK_V1_DIR=/home/ubuntu/opt/orbbec-sdk-v1.10.35-arm64/OrbbecSDK_v1.10.35/SDK

# Built binary path. Keep this default when deploying to /home/ubuntu/rm_robot_rust
# and building with --target aarch64-unknown-linux-gnu.
VISION_SENDER_BIN=/home/ubuntu/rm_robot_rust/sbc/orange_pi_vision/target/aarch64-unknown-linux-gnu/release/send_camera_to_robot

# Choose exactly one output. Serial is intended for the C board; UDP is useful for tests.
VISION_SERIAL=/dev/ttyAMA0
# VISION_UDP=127.0.0.1:5000

VISION_BAUD=921600
VISION_RATE_HZ=10
VISION_RGB_SIZE=640x480
# VISION_NO_RGB=1
